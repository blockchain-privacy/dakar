DGRAPH_PATH=/mnt/dgraph/production
BULK_PATH=/mnt/dgraph/bulk
DASH_PATH=/mnt/chaindata/dash
BITCOIN_PATH=/mnt/chaindata/bitcoin
# Use if whole network should have access to the container
#CONTAINER_IP=0.0.0.0
# Use if the container should be accessible from the local machine
CONTAINER_IP=127.0.0.1
KRATOS_POSTGRES_USER=kratos
KRATOS_POSTGRES_PASSWORD=change_me
# set if kratos should be started in dev mode
#KRATOS_DEV_CLI_PARAMETERS=--dev
# has to be 32 characters long
KRATOS_SECRETS_COOKIE=change_me
# has to be 32 characters long
KRATOS_SECRETS_CIPHER=change_me
